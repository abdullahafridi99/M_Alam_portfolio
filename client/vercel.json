{
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-render-backend-url.onrender.com/api/:path*"
    },
    {
      "source": "/uploads/:path*",
      "destination": "https://your-render-backend-url.onrender.com/uploads/:path*"
    }
  ]
}
